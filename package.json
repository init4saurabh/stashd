{
  "name": "stashd",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./apps/**\" --if-present run typecheck",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "dev:server": "pnpm --filter @stashd/server run dev",
    "dev:client": "pnpm --filter @stashd/client run dev",
    "db:push": "pnpm --filter @stashd/db run push"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
}